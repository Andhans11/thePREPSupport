# Copy to .env.functions and fill in values, then run:
#   npx supabase secrets set --env-file .env.functions
# Do not commit .env.functions (add to .gitignore).

GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Production: same URL as in Google Console "Authorized redirect URIs" and frontend VITE_GOOGLE_REDIRECT_URI.
REDIRECT_URI=https://your-app-domain.com/oauth/callback
# Optional: only if you use VITE_GOOGLE_CALENDAR_REDIRECT_URI for Calendar; must match that value exactly.
# REDIRECT_URI_CALENDAR=https://your-app-domain.com/oauth/callback/calendar
# Comma-separated extra URIs allowed for token exchange (e.g. local dev). Client sends the same redirect_uri it used in the authorize URL.
# ALLOWED_REDIRECT_URIS=http://localhost:5173/oauth/callback,http://localhost:5173/oauth/callback/calendar
