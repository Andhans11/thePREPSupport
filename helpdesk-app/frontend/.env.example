VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
# Production: your app origin + /oauth/callback. Must match backend REDIRECT_URI and Google Console exactly.
VITE_GOOGLE_REDIRECT_URI=https://your-app-domain.com/oauth/callback
# Optional: separate redirect for Calendar only (e.g. .../oauth/callback/calendar). Must match Supabase secret REDIRECT_URI_CALENDAR and Google Console.
# VITE_GOOGLE_CALENDAR_REDIRECT_URI=https://your-app-domain.com/oauth/callback/calendar
# Supabase Edge Function must allow the same URI: set ALLOWED_REDIRECT_URIS (e.g. localhost) or REDIRECT_URI to match — see backend .env.functions.example.
# Google Client ID/Secret are per tenant only (E-post innbokser, admin). No shared client.
